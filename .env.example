# Postgres (used by docker-compose and the app)
POSTGRES_USER=atrium
POSTGRES_PASSWORD=atrium
POSTGRES_DB=atrium

# App DB connection.
# Local dev (host -> db on mapped port): use localhost.
# Inside docker-compose this is overridden to host "db" (see docker-compose.yml).
DATABASE_URL=postgres://atrium:atrium@localhost:5432/atrium

# Better Auth
# Generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Web (Vite, baked in at build time)
VITE_API_URL=http://localhost:3000
